# API Configuration
# Use the environment variable NEXT_PUBLIC_API_URL to set the API endpoint
# This is a NEXT_PUBLIC variable, so it's included in the browser bundle
NEXT_PUBLIC_API_URL=https://geekink-cloud-sp39l.ondigitalocean.app/api/v1

# For local development, you can override this:
# NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Analytics (Optional)
VERCEL_WEB_ANALYTICS_ID=

# Additional Environment Variables (Vercel-specific, optional)
# AI_GATEWAY_API_KEY=
# VERCEL_OIDC_TOKEN=
